# Multiple Linear Regression (2 Variables)
import numpy as np

# x1, x2
X = np.array([
    [1, 2],
    [2, 1],
    [3, 4],
    [4, 3],
    [5, 5]
], dtype=float)

# Target variable
y = np.array([10, 8, 20, 18, 25], dtype=float)

X = np.column_stack((np.ones(len(X)), X))
beta = np.linalg.inv(X.T @ X) @ X.T @ y

print("Intercept =", beta[0])
print("b1 =", beta[1])
print("b2 =", beta[2])
