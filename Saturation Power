# Saturation Power
import numpy as np

x = np.array([1, 2, 3, 4, 5], dtype=float)
y = np.array([2, 4, 5, 4, 5], dtype=float)

for degree in range(1, 8):
    coeffs = np.polyfit(x, y, degree)
    poly = np.poly1d(coeffs)
    y_pred = poly(x)

    mse = np.mean((y - y_pred) ** 2)
    print(f"Degree {degree}: MSE = {mse:.6f}")
